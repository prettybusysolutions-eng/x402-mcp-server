{
  "name": "@prettybusysolutions-eng/x402-mcp-server",
  "version": "1.0.0",
  "description": "A paid, x402-compliant MCP server for on-chain contract analysis and data enrichment. Settles autonomously via USDC on Base Mainnet.",
  "main": "mcp-server.js",
  "bin": {
    "x402-mcp-server": "./mcp-server.js"
  },
  "scripts": {
    "test": "node -c mcp-server.js",
    "start": "node server.js",
    "mcp:start": "node mcp-server.js",
    "mcp:meta": "mcporter call --stdio 'node mcp-server.js' x402_metadata"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "x402",
    "base",
    "usdc",
    "contract-analysis",
    "data-enrichment",
    "web3-payment"
  ],
  "author": "Pretty Busy Solutions",
  "license": "MIT",
  "type": "commonjs",
  "files": [
    "mcp-server.js",
    "server.js",
    "MCP-README.md",
    "mcp.json",
    "smithery.yaml"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@coinbase/cdp-sdk": "^1.49.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@x402/core": "^2.12.0",
    "@x402/evm": "^2.12.0",
    "@x402/express": "^2.12.0",
    "@x402/extensions": "^2.12.0",
    "express": "^5.2.1"
  }
}
